# Copy this file to ".env" and fill in the values from your Supabase project:
# Supabase dashboard -> Project Settings -> API
#
# The EXPO_PUBLIC_ prefix is required so Expo exposes these to the app at runtime.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
